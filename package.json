{
  "name": "survey-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix backend install",
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "build": "run-s build:frontend build:backend",
    "build:frontend": "run-p typecheck:frontend \"build-only {@}\" --",
    "build-only": "vite build",
    "build:backend": "npm --prefix backend run build",
    "preview": "vite preview",
    "test": "run-s test:frontend test:backend",
    "test:frontend": "vitest run --dir src",
    "test:backend": "npm --prefix backend run test",
    "test:unit": "run-s test:frontend test:backend:unit",
    "test:backend:unit": "npm --prefix backend run test:unit",
    "test:functional": "run-s test:frontend:functional test:backend:functional",
    "test:frontend:functional": "vitest run src/__tests__/RespondentView.functional.spec.ts",
    "test:backend:functional": "npm --prefix backend run test:functional",
    "typecheck": "run-s typecheck:frontend typecheck:backend",
    "typecheck:frontend": "vue-tsc --build",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "lint": "run-s lint:frontend lint:backend",
    "lint:frontend": "run-s lint:oxlint lint:eslint",
    "lint:backend": "npm --prefix backend run lint",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint src shared env.d.ts vite.config.ts vitest.config.ts eslint.config.ts --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "validate": "run-s lint typecheck build test prisma:validate",
    "check": "run-s lint typecheck test",
    "db:up": "docker compose -f backend/docker-compose.yml up -d",
    "db:seed": "npm --prefix backend run db:seed",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:validate": "npm --prefix backend run prisma:validate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "prisma:migrate:test": "npm --prefix backend run prisma:migrate:test",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/__tests__/accessibility.static.spec.ts",
    "test:e2e": "run-s test:frontend:functional test:backend:functional",
    "preprod:up": "docker compose -f docker-compose.preprod.yml --env-file .env.preprod up --build -d",
    "preprod:down": "docker compose -f docker-compose.preprod.yml --env-file .env.preprod down",
    "preprod:logs": "docker compose -f docker-compose.preprod.yml --env-file .env.preprod logs -f --tail=200",
    "backup:encrypted": "docker compose -f docker-compose.preprod.yml --env-file .env.preprod run --rm encrypted-backup"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "pinia": "3.0.4",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/jsdom": "28.0.3",
    "@types/node": "22.19.21",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/eslint-plugin": "1.6.16",
    "@vue/eslint-config-typescript": "14.8.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.60.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "29.1.1",
    "npm-run-all2": "8.0.4",
    "oxlint": "1.60.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-vue-devtools": "8.1.1",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  },
  "engines": {
    "node": "22.18.x",
    "npm": "10.9.x"
  },
  "description": "Quiz structuré avec routing par rôle et socle backend/shared.",
  "packageManager": "npm@10.9.2"
}
