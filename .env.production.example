# Copy to .env.production and replace every CHANGEME value through the approved secret manager.
NODE_ENV=production
CHPM_RELEASE_VERSION=1.0.0
CHPM_HOSTNAME=questionnaires.example.org
FRONTEND_ORIGIN=https://questionnaires.example.org
TLS_CERT_DIR=/srv/chpm/tls
BACKUP_OUTPUT_DIR=/srv/chpm/backups

# Pin infrastructure images by immutable digest before deployment.
POSTGRES_IMAGE=postgres:17.5-alpine@sha256:CHANGEME-64-hex-digest
NGINX_IMAGE=nginx:1.27-alpine@sha256:CHANGEME-64-hex-digest
NODE_IMAGE=node:22.18.0-bookworm-slim@sha256:CHANGEME-64-hex-digest

POSTGRES_DB=chpm_quiz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME-superuser-secret
POSTGRES_MIGRATOR_PASSWORD=CHANGEME-migrator-secret
POSTGRES_OPERATIONAL_PASSWORD=CHANGEME-operational-secret
POSTGRES_IDENTITY_PASSWORD=CHANGEME-identity-secret
POSTGRES_DPO_PASSWORD=CHANGEME-dpo-console-secret
MIGRATION_DATABASE_URL=postgresql://chpm_migrator:CHANGEME-migrator-secret@postgres:5432/chpm_quiz?schema=public
OPERATIONAL_DATABASE_URL=postgresql://chpm_operational:CHANGEME-operational-secret@postgres:5432/chpm_quiz?schema=public
IDENTITY_DATABASE_URL=postgresql://chpm_identity:CHANGEME-identity-secret@postgres:5432/chpm_quiz?schema=identity
DPO_DATABASE_URL=postgresql://chpm_dpo:CHANGEME-dpo-console-secret@postgres:5432/chpm_quiz?schema=public
DATABASE_URL=postgresql://chpm_operational:CHANGEME-operational-secret@postgres:5432/chpm_quiz?schema=public

PORT=3000
API_PREFIX=api
SESSION_COOKIE_NAME=__Host-chpm_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
TRUST_PROXY_HOPS=1
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15

AUTH_PROVIDER=oidc
ALLOW_LOCAL_AUTH_IN_PRODUCTION=false
AUTH_OIDC_ISSUER=https://identity.example.org
AUTH_OIDC_CLIENT_ID=CHANGEME-client-id
AUTH_OIDC_CLIENT_SECRET=CHANGEME-at-least-32-random-characters
AUTH_OIDC_REDIRECT_URI=https://questionnaires.example.org/api/auth/oidc/callback
AUTH_OIDC_SCOPES=openid email profile
AUTH_OIDC_REQUIRED_AMR=mfa

RESPONDENT_TOKEN_SECRET=CHANGEME-at-least-32-random-characters
RESPONDENT_TOKEN_TTL_DAYS=30
EMAIL_ENCRYPTION_KEY_B64=CHANGEME-32-byte-base64-key
EMAIL_HASH_PEPPER=CHANGEME-at-least-32-random-characters
JUDICIAL_EXPORT_KEY_B64=CHANGEME-32-byte-base64-key
JUDICIAL_EXPORT_TTL_MINUTES=60
# Break-glass local console remains disabled unless a formally approved run sets this to true.
CHPM_DPO_CONSOLE_ALLOW_PRODUCTION=false
EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=false

STATISTICS_MIN_GROUP_SIZE=10
DRAFT_RETENTION_DAYS=45
IDENTITY_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=730
RESPONSE_RETENTION_DAYS=730
ENABLE_RETENTION_WORKER=true
RETENTION_WORKER_INTERVAL_MINUTES=1440
DPO_CONTACT=dpo@example.org

EMAIL_PROVIDER=brevo
EMAIL_FROM=no-reply@example.org
EMAIL_FROM_NAME=CHPM Survey
BREVO_API_KEY=CHANGEME-provider-secret
EMAIL_JOB_MAX_ATTEMPTS=5
EMAIL_JOB_RETRY_DELAY_MS=1000
SMS_PROVIDER=disabled
SMS_SENDER=CHPM
SMS_JOB_MAX_ATTEMPTS=5
SMS_JOB_RETRY_DELAY_MS=1000
DELIVERY_QUEUE_POLL_MS=2000
PROVIDER_HTTP_TIMEOUT_MS=10000
METRICS_TOKEN=CHANGEME-at-least-32-random-characters
ENABLE_NOTIFICATION_DIGEST_WORKER=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=3600000

VITE_APP_NAME=CHPM Survey
VITE_APP_DESCRIPTION=Secure questionnaire and pseudonymized survey platform.
VITE_DEFAULT_LOCALE=en
VITE_I18N_CONTENT_BASE_URL=/content/i18n

BACKUP_ENCRYPTION_PASSPHRASE=CHANGEME-vault-managed-backup-passphrase

# Required only for the one-time bootstrap profile.
BOOTSTRAP_ORGANIZATION_CODE=CHPM
BOOTSTRAP_ORGANIZATION_NAME=Centre Hospitalier de Montfavet
BOOTSTRAP_SITE_CODE=MAIN
BOOTSTRAP_SITE_NAME=Main site
BOOTSTRAP_BUILDING_CODE=MAIN-A
BOOTSTRAP_BUILDING_LABEL=Main building
BOOTSTRAP_CITY=Montfavet
BOOTSTRAP_COUNTRY=France
BOOTSTRAP_TIMEZONE=Europe/Paris
BOOTSTRAP_ADMIN_EMAIL=admin@example.org
BOOTSTRAP_ADMIN_DISPLAY_NAME=Initial project administrator
BOOTSTRAP_ADMIN_PASSWORD=CHANGEME-one-time-strong-password
