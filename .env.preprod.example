# Copier en .env.preprod. Ne jamais committer .env.preprod.
NODE_ENV=preproduction
VITE_DEFAULT_LOCALE=fr
VITE_APP_NAME="CHPM Survey"
VITE_I18N_CONTENT_BASE_URL=/content/i18n
PUBLIC_BASE_URL=https://questionnaires.example.org
FRONTEND_ORIGIN=https://questionnaires.example.org
TLS_CERT_DIR=./ops/tls-dev

POSTGRES_DB=chpm_quiz
POSTGRES_USER=chpm_preprod
POSTGRES_PASSWORD=replace-with-vault-managed-password
OPERATIONAL_DATABASE_URL=postgresql://chpm_preprod:replace-with-vault-managed-password@postgres:5432/chpm_quiz?schema=public
IDENTITY_DATABASE_URL=postgresql://chpm_preprod:replace-with-vault-managed-password@postgres:5432/chpm_quiz?schema=identity
DATABASE_URL=postgresql://chpm_preprod:replace-with-vault-managed-password@postgres:5432/chpm_quiz?schema=public

PORT=3000
API_PREFIX=api
SESSION_COOKIE_NAME=__Host-chpm_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
RESPONDENT_TOKEN_SECRET=replace-with-at-least-32-random-characters
RESPONDENT_TOKEN_TTL_DAYS=30
STATISTICS_MIN_GROUP_SIZE=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
DRAFT_RETENTION_DAYS=45
IDENTITY_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=730
DPO_CONTACT=dpo@example.org

# Générer avec: openssl rand -base64 32
EMAIL_ENCRYPTION_KEY_B64=replace-with-32-byte-base64-key
EMAIL_HASH_PEPPER=replace-with-long-random-pepper
JUDICIAL_EXPORT_KEY_B64=replace-with-32-byte-base64-key

EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=false
AUTH_PROVIDER=local
AUTH_CALLBACK_PATH=/api/auth/callback

# En préprod connectée, choisir brevo, sendgrid ou mailjet. La simulation est bloquée par validation stricte.
EMAIL_PROVIDER=brevo
EMAIL_FROM=no-reply@example.org
EMAIL_FROM_NAME="CHPM Questionnaires"
EMAIL_JOB_MAX_ATTEMPTS=3
EMAIL_JOB_RETRY_DELAY_MS=1000

# SMS sortant : mettre disabled si le canal SMS n'est pas encore contractualisé.
SMS_PROVIDER=disabled
SMS_SENDER=CHPM
SMS_JOB_MAX_ATTEMPTS=3
SMS_JOB_RETRY_DELAY_MS=1000
# Pour Twilio : TWILIO_ACCOUNT_SID=... TWILIO_AUTH_TOKEN=... TWILIO_FROM=+33...
# Pour Brevo SMS : BREVO_API_KEY=...
BREVO_API_KEY=replace-with-vault-secret
SENDGRID_API_KEY=
MAILJET_API_KEY=
MAILJET_API_SECRET=
ENABLE_NOTIFICATION_DIGEST_WORKER=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=3600000

BACKUP_OUTPUT_DIR=./backups
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-vault-managed-passphrase
