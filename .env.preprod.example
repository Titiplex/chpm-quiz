# Copy to .env.preprod. Never commit .env.preprod.
NODE_ENV=preproduction
VITE_DEFAULT_LOCALE=fr
VITE_APP_DESCRIPTION="Secure questionnaire, invitation, response, and pseudonymized statistics platform."
VITE_APP_NAME="CHPM Survey"
VITE_I18N_CONTENT_BASE_URL=/content/i18n
PUBLIC_BASE_URL=https://questionnaires.example.org
FRONTEND_ORIGIN=https://questionnaires.example.org
TLS_CERT_DIR=./ops/tls-dev

POSTGRES_DB=chpm_quiz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-vault-managed-superuser-password
POSTGRES_MIGRATOR_PASSWORD=replace-with-vault-managed-migrator-password
POSTGRES_OPERATIONAL_PASSWORD=replace-with-vault-managed-operational-password
POSTGRES_IDENTITY_PASSWORD=replace-with-vault-managed-identity-password
POSTGRES_DPO_PASSWORD=replace-with-vault-managed-dpo-console-password
MIGRATION_DATABASE_URL=postgresql://chpm_migrator:replace-with-vault-managed-migrator-password@postgres:5432/chpm_quiz?schema=public
OPERATIONAL_DATABASE_URL=postgresql://chpm_operational:replace-with-vault-managed-operational-password@postgres:5432/chpm_quiz?schema=public
IDENTITY_DATABASE_URL=postgresql://chpm_identity:replace-with-vault-managed-identity-password@postgres:5432/chpm_quiz?schema=identity
DPO_DATABASE_URL=postgresql://chpm_dpo:replace-with-vault-managed-dpo-console-password@postgres:5432/chpm_quiz?schema=public
DATABASE_URL=postgresql://chpm_operational:replace-with-vault-managed-operational-password@postgres:5432/chpm_quiz?schema=public

PORT=3000
API_PREFIX=api
SESSION_COOKIE_NAME=__Host-chpm_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
RESPONDENT_TOKEN_SECRET=replace-with-at-least-32-random-characters
RESPONDENT_TOKEN_TTL_DAYS=30
STATISTICS_MIN_GROUP_SIZE=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
TRUST_PROXY_HOPS=1
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
DRAFT_RETENTION_DAYS=45
IDENTITY_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=730
RESPONSE_RETENTION_DAYS=730
ENABLE_RETENTION_WORKER=true
RETENTION_WORKER_INTERVAL_MINUTES=1440
DPO_CONTACT=dpo@example.org

# Generate with: openssl rand -base64 32
EMAIL_ENCRYPTION_KEY_B64=replace-with-32-byte-base64-key
EMAIL_HASH_PEPPER=replace-with-long-random-pepper
JUDICIAL_EXPORT_KEY_B64=replace-with-32-byte-base64-key
JUDICIAL_EXPORT_TTL_MINUTES=60
CHPM_DPO_CONSOLE_ALLOW_PRODUCTION=false
METRICS_TOKEN=replace-with-at-least-32-random-characters

EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=false
AUTH_PROVIDER=local
# This is an explicit preproduction exception. Production must use OIDC with MFA.
ALLOW_LOCAL_AUTH_IN_PRODUCTION=true

# Connected preproduction uses brevo, sendgrid, or mailjet. Strict validation rejects simulation.
EMAIL_PROVIDER=brevo
EMAIL_FROM=no-reply@example.org
EMAIL_FROM_NAME="CHPM Survey"
EMAIL_JOB_MAX_ATTEMPTS=3
EMAIL_JOB_RETRY_DELAY_MS=1000
DELIVERY_QUEUE_POLL_MS=2000
PROVIDER_HTTP_TIMEOUT_MS=10000

# Outbound SMS: use disabled until an approved SMS provider contract is in place.
SMS_PROVIDER=disabled
SMS_SENDER=CHPM
SMS_JOB_MAX_ATTEMPTS=3
SMS_JOB_RETRY_DELAY_MS=1000
# Twilio: TWILIO_ACCOUNT_SID=... TWILIO_AUTH_TOKEN=... TWILIO_FROM=+33...
# Brevo SMS: BREVO_API_KEY=...
BREVO_API_KEY=replace-with-vault-secret
SENDGRID_API_KEY=
MAILJET_API_KEY=
MAILJET_API_SECRET=
ENABLE_NOTIFICATION_DIGEST_WORKER=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=3600000

BACKUP_OUTPUT_DIR=./backups
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-vault-managed-passphrase
