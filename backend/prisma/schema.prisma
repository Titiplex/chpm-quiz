generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "identity"]
}

enum UserRole {
  admin
  moderator
  site_manager
  questionnaire_admin
  analyst
  dpo
  judicial_officer
  technical_admin
  service_account
  respondent
  @@schema("public")
}

enum QuestionnaireStatus {
  draft
  published
  archived
  @@schema("public")
}

enum QuestionnaireVersionStatus {
  draft
  published
  archived
  @@schema("public")
}

enum QuestionType {
  single_choice
  multiple_choice
  likert
  free_text
  free_text_short
  free_text_long
  number
  date
  information
  @@schema("public")
}

enum InvitationStatus {
  pending
  sent
  opened
  in_progress
  draft
  submitted
  expired
  blocked
  cancelled
  @@schema("public")
}

enum ResponseSessionStatus {
  draft
  submitted
  locked
  abandoned
  @@schema("public")
}

enum InvitationDeliveryMode {
  email
  email_simulation
  sms
  sms_simulation
  onsite_terminal
  @@schema("public")
}

enum AssistanceMode {
  none
  technical_help
  full_assisted_entry
  @@schema("public")
}

enum TerminalDeviceStatus {
  active
  paused
  revoked
  @@schema("public")
}

enum JudicialAccessStatus {
  received
  validated
  rejected
  executed
  closed
  @@schema("public")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites          Site[]
  buildings      Building[]
  users          User[]
  questionnaires Questionnaire[]
  @@schema("public")
}

model Site {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String       @unique
  name           String
  country        String
  timezone       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  buildings       Building[]
  users           User[]
  invitations     Invitation[]
  terminalDevices TerminalDevice[]

  @@index([organizationId])
  @@schema("public")
}

model Building {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  siteId         String       @db.Uuid
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  code           String       @unique
  label          String
  city           String
  country        String
  timezone       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users            User[]
  invitations      Invitation[]
  responseSessions ResponseSession[]
  submissions      Submission[]
  terminalDevices  TerminalDevice[]

  @@index([organizationId])
  @@index([siteId])
  @@schema("public")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  siteId         String?      @db.Uuid
  site           Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  buildingId     String?      @db.Uuid
  building       Building?    @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  email          String       @unique
  passwordHash   String
  displayName    String
  role           UserRole
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sessions                  Session[]
  ownedQuestionnaires       Questionnaire[]       @relation("QuestionnaireOwner")
  createdInvitations        Invitation[]          @relation("InvitationCreator")
  notificationSubscriptions NotificationSubscription[]
  auditLogs                 AuditLog[]            @relation("AuditActor")
  judicialRequestsDpo       JudicialAccessRequest[] @relation("JudicialDpoValidator")
  judicialRequestsLegal     JudicialAccessRequest[] @relation("JudicialLegalValidator")
  judicialRequestsExecuted  JudicialAccessRequest[] @relation("JudicialExecutor")

  @@index([role])
  @@index([organizationId])
  @@index([siteId])
  @@index([buildingId])
  @@schema("public")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  tokenHash  String   @unique
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

model Questionnaire {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String?             @db.Uuid
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  ownerUserId    String?             @db.Uuid
  owner          User?               @relation("QuestionnaireOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  code           String              @unique
  title          String
  description    String?
  defaultLanguage String             @default("fr")
  finality       String?
  status         QuestionnaireStatus @default(draft)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  versions QuestionnaireVersion[]

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([status])
  @@schema("public")
}

model QuestionnaireVersion {
  id                String                     @id @default(uuid()) @db.Uuid
  questionnaireId   String                     @db.Uuid
  questionnaire     Questionnaire              @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  versionLabel      String
  language          String                     @default("fr")
  status            QuestionnaireVersionStatus @default(draft)
  description       String?
  finality          String?
  openFrom          DateTime?
  openUntil         DateTime?
  publishedAt       DateTime?
  immutableAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  groups                    QuestionGroup[]
  conditionalRules          ConditionalRule[]
  invitations               Invitation[]
  notificationSubscriptions NotificationSubscription[]
  submissions               Submission[]

  @@unique([questionnaireId, versionLabel])
  @@index([questionnaireId])
  @@index([status])
  @@index([openFrom, openUntil])
  @@schema("public")
}

model QuestionGroup {
  id                     String               @id @default(uuid()) @db.Uuid
  questionnaireVersionId String               @db.Uuid
  questionnaireVersion   QuestionnaireVersion @relation(fields: [questionnaireVersionId], references: [id], onDelete: Cascade)
  title                  String
  description            String?
  displayOrder           Int
  questionsPerPage       Int                  @default(3)
  randomize              Boolean              @default(false)
  conditionExpression    Json?
  isArchived             Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  questions Question[]

  @@unique([questionnaireVersionId, displayOrder])
  @@index([questionnaireVersionId])
  @@index([isArchived])
  @@schema("public")
}

model Question {
  id             String        @id @default(uuid()) @db.Uuid
  groupId        String        @db.Uuid
  group          QuestionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  code           String
  language       String        @default("fr")
  label          String
  helperText     String?
  responseType   QuestionType
  isRequired     Boolean       @default(false)
  displayOrder   Int
  tags           String[]
  conditionExpression Json?
  isArchived     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  likertScale      LikertScale?
  answerOptions    AnswerOption[]
  popupDefinitions PopupDefinition[]
  answers          Answer[]
  telemetryEvents  TelemetryEvent[]

  @@unique([groupId, code])
  @@unique([groupId, displayOrder])
  @@index([groupId])
  @@index([responseType])
  @@index([isArchived])
  @@schema("public")
}

model AnswerOption {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @db.Uuid
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value        String
  label        String
  displayOrder Int
  isExclusive  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([questionId, value])
  @@index([questionId])
  @@schema("public")
}

model LikertScale {
  id                 String   @id @default(uuid()) @db.Uuid
  questionId         String   @unique @db.Uuid
  question           Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  points             Int
  minValue           Int      @default(1)
  leftAnchor         String
  rightAnchor        String
  neutralLabel       String?
  allowNotApplicable Boolean  @default(false)
  orientation        String   @default("horizontal")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@schema("public")
}

model GlossaryTerm {
  id        String   @id @default(uuid()) @db.Uuid
  termKey   String
  language  String   @default("fr")
  label     String
  definition String
  version   String   @default("1.0")
  isArchived Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  popupDefinitions PopupDefinition[]

  @@unique([termKey, language, version])
  @@index([termKey])
  @@index([language])
  @@schema("public")
}

model PopupDefinition {
  id           String       @id @default(uuid()) @db.Uuid
  questionId   String       @db.Uuid
  question     Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  glossaryTermId String?    @db.Uuid
  glossaryTerm GlossaryTerm? @relation(fields: [glossaryTermId], references: [id], onDelete: SetNull)
  termKey      String
  language     String       @default("fr")
  title        String
  body         String
  version      String       @default("1.0")
  isRequired   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  telemetryEvents TelemetryEvent[]

  @@index([questionId])
  @@index([glossaryTermId])
  @@index([termKey, language])
  @@schema("public")
}

model ConditionalRule {
  id                     String               @id @default(uuid()) @db.Uuid
  questionnaireVersionId String               @db.Uuid
  questionnaireVersion   QuestionnaireVersion @relation(fields: [questionnaireVersionId], references: [id], onDelete: Cascade)
  code                   String
  trigger                Json
  effect                 Json
  priority               Int                  @default(100)
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([questionnaireVersionId, code])
  @@index([questionnaireVersionId])
  @@schema("public")
}

model Invitation {
  id                     String               @id @default(uuid()) @db.Uuid
  questionnaireVersionId String               @db.Uuid
  questionnaireVersion   QuestionnaireVersion @relation(fields: [questionnaireVersionId], references: [id], onDelete: Restrict)
  siteId                 String?              @db.Uuid
  site                   Site?                @relation(fields: [siteId], references: [id], onDelete: SetNull)
  buildingId             String               @db.Uuid
  building               Building             @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  createdByUserId        String?              @db.Uuid
  createdBy              User?                @relation("InvitationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publicCode             String                 @unique
  tokenHash              String                 @unique
  status                 InvitationStatus       @default(sent)
  deliveryMode           InvitationDeliveryMode @default(email_simulation)
  terminalDeviceId       String?                @db.Uuid
  terminalDevice         TerminalDevice?        @relation(fields: [terminalDeviceId], references: [id], onDelete: SetNull)
  terminalDispatchedAt   DateTime?
  assistanceMode         AssistanceMode         @default(none)
  notifyModerator        Boolean              @default(false)
  notifyAdmins           Boolean              @default(false)
  expiresAt              DateTime
  sentAt                 DateTime?
  openedAt               DateTime?
  startedAt              DateTime?
  submittedAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  identityVaultEntry  IdentityVaultEntry?
  deliveryEvents EmailDeliveryEvent[]
  responseSession ResponseSession?

  @@index([questionnaireVersionId])
  @@index([buildingId])
  @@index([siteId])
  @@index([createdByUserId])
  @@index([status])
  @@index([expiresAt])
  @@index([deliveryMode])
  @@index([terminalDeviceId])
  @@schema("public")
}

model IdentityVaultEntry {
  id                     String     @id @default(uuid()) @db.Uuid
  invitationId           String     @unique @db.Uuid
  invitation             Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  uniqueCode             String     @unique @map("publicCode")
  contactChannel         String     @default("email")
  encryptedEmail         String?    @map("emailCiphertext")
  emailHash              String?
  encryptedPhone         String?    @map("phoneCiphertext")
  phoneHash              String?
  questionnaireVersionId String     @db.Uuid
  buildingId             String     @db.Uuid
  createdByUserId        String?    @db.Uuid
  createdAt              DateTime   @default(now())
  lastEmailSentAt        DateTime?
  lastSmsSentAt          DateTime?
  deletionScheduledAt    DateTime?
  deletedAt              DateTime?

  @@map("email_identities")
  @@index([contactChannel])
  @@index([emailHash])
  @@index([phoneHash])
  @@index([uniqueCode])
  @@schema("identity")
}

model TerminalDevice {
  id              String               @id @default(uuid()) @db.Uuid
  organizationId  String?              @db.Uuid
  siteId          String?              @db.Uuid
  site            Site?                @relation(fields: [siteId], references: [id], onDelete: SetNull)
  buildingId      String               @db.Uuid
  building        Building             @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  createdByUserId String?              @db.Uuid
  code            String               @unique
  label           String
  accessTokenHash String               @unique
  status          TerminalDeviceStatus @default(active)
  lastSeenAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  invitations      Invitation[]
  responseSessions ResponseSession[]

  @@index([organizationId])
  @@index([siteId])
  @@index([buildingId])
  @@index([status])
  @@schema("public")
}

model EmailDeliveryEvent {
  id                String     @id @default(uuid()) @db.Uuid
  invitationId      String     @db.Uuid
  invitation        Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  publicCode        String
  eventType         String
  providerMessageId String?
  metadata          Json?
  occurredAt        DateTime   @default(now())

  @@map("email_delivery_events")
  @@index([invitationId])
  @@index([publicCode])
  @@index([eventType])
  @@schema("identity")
}

model IdentityVaultAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @db.Uuid
  action        String
  publicCode    String?
  requestId     String?  @db.Uuid
  ipAddress     String?
  metadata      Json?
  occurredAt    DateTime @default(now())

  @@map("vault_audit_logs")
  @@index([actorUserId])
  @@index([publicCode])
  @@index([requestId])
  @@schema("identity")
}

model ResponseSession {
  id                     String                @id @default(uuid()) @db.Uuid
  invitationId           String                @unique @db.Uuid
  invitation             Invitation            @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  publicCode             String
  questionnaireVersionId String                @db.Uuid
  buildingId             String                @db.Uuid
  building               Building              @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  terminalDeviceId       String?               @db.Uuid
  terminalDevice         TerminalDevice?       @relation(fields: [terminalDeviceId], references: [id], onDelete: SetNull)
  assistanceMode         AssistanceMode        @default(none)
  assistedByUserId       String?               @db.Uuid
  assistanceDeclaredAt   DateTime?
  status                 ResponseSessionStatus @default(draft)
  currentPage            Int                   @default(1)
  randomizationSeed      String
  pathFingerprint        String?
  startedAt              DateTime              @default(now())
  lastSeenAt             DateTime              @default(now())
  submittedAt            DateTime?
  lockedAt               DateTime?

  answers         Answer[]
  telemetryEvents TelemetryEvent[]
  submission      Submission?

  @@index([publicCode])
  @@index([questionnaireVersionId])
  @@index([buildingId])
  @@index([terminalDeviceId])
  @@index([assistanceMode])
  @@index([status])
  @@schema("public")
}

model Answer {
  id                    String          @id @default(uuid()) @db.Uuid
  responseSessionId     String          @db.Uuid
  responseSession       ResponseSession @relation(fields: [responseSessionId], references: [id], onDelete: Cascade)
  questionId            String          @db.Uuid
  question              Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)
  value                 Json
  isDraft               Boolean         @default(true)
  identifiabilityWarning Boolean        @default(false)
  warningReason         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([responseSessionId, questionId])
  @@index([questionId])
  @@schema("public")
}

model TelemetryEvent {
  id                String          @id @default(uuid()) @db.Uuid
  responseSessionId String          @db.Uuid
  responseSession   ResponseSession @relation(fields: [responseSessionId], references: [id], onDelete: Cascade)
  questionId        String?         @db.Uuid
  question          Question?       @relation(fields: [questionId], references: [id], onDelete: SetNull)
  popupDefinitionId String?         @db.Uuid
  popupDefinition   PopupDefinition? @relation(fields: [popupDefinitionId], references: [id], onDelete: SetNull)
  eventType         String
  eventPayload      Json?
  durationMs        Int?
  occurredAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())

  @@index([responseSessionId])
  @@index([questionId])
  @@index([popupDefinitionId])
  @@index([eventType])
  @@index([occurredAt])
  @@schema("public")
}

model Submission {
  id                     String              @id @default(uuid()) @db.Uuid
  responseSessionId      String              @unique @db.Uuid
  responseSession        ResponseSession     @relation(fields: [responseSessionId], references: [id], onDelete: Cascade)
  publicCode             String
  questionnaireVersionId String              @db.Uuid
  questionnaireVersion   QuestionnaireVersion @relation(fields: [questionnaireVersionId], references: [id], onDelete: Restrict)
  buildingId             String              @db.Uuid
  building               Building            @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  submittedAt            DateTime            @default(now())
  answerCount            Int
  pathFingerprint        String?
  status                 String              @default("locked")

  @@index([publicCode])
  @@index([questionnaireVersionId])
  @@index([buildingId])
  @@index([submittedAt])
  @@schema("public")
}

model NotificationSubscription {
  id                     String               @id @default(uuid()) @db.Uuid
  userId                 String               @db.Uuid
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionnaireVersionId String?              @db.Uuid
  questionnaireVersion   QuestionnaireVersion? @relation(fields: [questionnaireVersionId], references: [id], onDelete: Cascade)
  buildingId             String?              @db.Uuid
  eventType              String
  channel                String               @default("email")
  frequency              String               @default("immediate")
  digestHour             Int                  @default(8)
  isEnabled              Boolean              @default(true)
  lastDeliveredAt        DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([userId])
  @@index([questionnaireVersionId])
  @@index([buildingId])
  @@index([eventType])
  @@index([frequency])
  @@index([lastDeliveredAt])
  @@schema("public")
}

model JudicialAccessRequest {
  id                       String               @id @default(uuid()) @db.Uuid
  requestReference         String               @unique
  legalBasisDescription    String
  courtOrderReference      String?
  requestedPublicCodes     String[]
  requestedBy              String
  receivedAt               DateTime             @default(now())
  dpoValidationUserId      String?              @db.Uuid
  dpoValidationUser        User?                @relation("JudicialDpoValidator", fields: [dpoValidationUserId], references: [id], onDelete: SetNull)
  legalValidationUserId    String?              @db.Uuid
  legalValidationUser      User?                @relation("JudicialLegalValidator", fields: [legalValidationUserId], references: [id], onDelete: SetNull)
  executedByUserId         String?              @db.Uuid
  executedByUser           User?                @relation("JudicialExecutor", fields: [executedByUserId], references: [id], onDelete: SetNull)
  status                   JudicialAccessStatus @default(received)
  executedAt               DateTime?
  exportFingerprint        String?
  comments                 String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([status])
  @@index([receivedAt])
  @@schema("public")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  publicCode  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([entityType])
  @@index([publicCode])
  @@index([occurredAt])
  @@schema("public")
}
