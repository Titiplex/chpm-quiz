{
  "name": "quiz-backend",
  "version": "0.2.0",
  "private": true,
  "description": "API centrale NestJS pour Quiz.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "predev": "npm run prisma:generate",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts --exclude \"**/*.functional.spec.ts\"",
    "test:functional": "vitest run --config vitest.config.ts \"src/**/*.functional.spec.ts\"",
    "prisma:generate": "node scripts/prisma.mjs generate",
    "prisma:validate": "node scripts/prisma.mjs validate",
    "prisma:migrate": "node scripts/prisma.mjs migrate dev",
    "prisma:migrate:test": "node scripts/prisma.mjs migrate reset --force --skip-generate && npm run prisma:generate && npm run db:seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "node scripts/prisma.mjs migrate reset --force",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.27",
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "cookie-parser": "1.4.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.26",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "22.19.21",
    "@types/supertest": "6.0.3",
    "prisma": "6.19.3",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "ts-loader": "9.6.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.18.x",
    "npm": "10.9.x"
  },
  "overrides": {
    "multer": "2.2.0"
  }
}
