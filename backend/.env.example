DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=public"
PORT=3000
API_PREFIX=api
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=chpm_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=false
RESPONDENT_TOKEN_SECRET=dev-respondent-token-secret-change-me
RESPONDENT_TOKEN_TTL_DAYS=30
STATISTICS_MIN_GROUP_SIZE=5
# Production: générer avec `openssl rand -base64 32`; obligatoire pour chiffrer les emails au repos.
EMAIL_ENCRYPTION_KEY_B64=""
# Secret HMAC distinct pour la recherche de doublons sans stocker l'email en clair.
EMAIL_HASH_PEPPER=""
# Clé distincte pour les exports judiciaires chiffrés; générer avec `openssl rand -base64 32`.
JUDICIAL_EXPORT_KEY_B64=""
# Secrets de développement uniquement, jamais en production.
DEV_EMAIL_ENCRYPTION_SECRET=development-email-key-change-me
DEV_EMAIL_HASH_PEPPER=development-email-pepper-change-me
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
DRAFT_RETENTION_DAYS=45
IDENTITY_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=730
DPO_CONTACT=dpo@chpm.local
ENABLE_NOTIFICATION_DIGEST_WORKER=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=3600000

# Séparation logique/credentials : utiliser deux utilisateurs PostgreSQL en production.
OPERATIONAL_DATABASE_URL="postgresql://chpm_app:change-me@localhost:5432/chpm_quiz?schema=public"
IDENTITY_DATABASE_URL="postgresql://chpm_identity:change-me@localhost:5432/chpm_quiz?schema=identity"
EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=true

# Préparation fédération d'identité future. En MVP, AUTH_PROVIDER reste local.
AUTH_PROVIDER=local
AUTH_OIDC_ISSUER=""
AUTH_SAML_ENTITY_ID=""
AUTH_AUDIENCE=""
AUTH_METADATA_URL=""
AUTH_CALLBACK_PATH=/api/auth/callback

# Email sortant réel. En production, EMAIL_PROVIDER ne doit jamais rester sur simulation.
EMAIL_PROVIDER=simulation
EMAIL_FROM=no-reply@chpm.local
EMAIL_FROM_NAME="CHPM Questionnaires"
EMAIL_JOB_MAX_ATTEMPTS=3
EMAIL_JOB_RETRY_DELAY_MS=1000
BREVO_API_KEY=""
SENDGRID_API_KEY=""
MAILJET_API_KEY=""
MAILJET_API_SECRET=""
