DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=public"
PORT=3000
API_PREFIX=api
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=chpm_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
RESPONDENT_TOKEN_SECRET=dev-respondent-token-secret-change-me
RESPONDENT_TOKEN_TTL_DAYS=30
STATISTICS_MIN_GROUP_SIZE=5
# Production: generate with `openssl rand -base64 32`; required to encrypt contact data at rest.
EMAIL_ENCRYPTION_KEY_B64=""
# Separate HMAC secret for duplicate detection without storing a clear email value.
EMAIL_HASH_PEPPER=""
# Separate key for encrypted judicial exports; generate with `openssl rand -base64 32`.
JUDICIAL_EXPORT_KEY_B64=""
# Development-only secrets; never use in production.
DEV_EMAIL_ENCRYPTION_SECRET=development-email-key-change-me
DEV_EMAIL_HASH_PEPPER=development-email-pepper-change-me
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
TRUST_PROXY_HOPS=0
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
DRAFT_RETENTION_DAYS=45
IDENTITY_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=730
RESPONSE_RETENTION_DAYS=730
ENABLE_RETENTION_WORKER=false
RETENTION_WORKER_INTERVAL_MINUTES=1440
JUDICIAL_EXPORT_TTL_MINUTES=60
DPO_CONTACT=dpo@chpm.local
ENABLE_NOTIFICATION_DIGEST_WORKER=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=3600000

# Local development: Docker Compose creates one PostgreSQL user, chpm/chpm.
# Production: use two distinct PostgreSQL users and strong managed secrets.
OPERATIONAL_DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=public"
IDENTITY_DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=identity"
# The local development database may reuse one role. Production console runs require the dedicated chpm_dpo role.
DPO_DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=public"
EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=true

# Local development uses passwords. Production uses the OIDC settings below and requires MFA.
AUTH_PROVIDER=local
AUTH_OIDC_ISSUER=""
AUTH_OIDC_CLIENT_ID=""
AUTH_OIDC_CLIENT_SECRET=""
AUTH_OIDC_REDIRECT_URI=""
AUTH_OIDC_SCOPES="openid email profile"
AUTH_OIDC_REQUIRED_ACR=""
AUTH_OIDC_REQUIRED_AMR=""

# Outbound email. EMAIL_PROVIDER must never remain simulation in production.
# Production/preproduction: brevo|sendgrid|mailjet; strict validation rejects simulation.
EMAIL_PROVIDER=simulation
EMAIL_FROM=no-reply@chpm.local
EMAIL_FROM_NAME="CHPM Survey"
EMAIL_JOB_MAX_ATTEMPTS=3
EMAIL_JOB_RETRY_DELAY_MS=1000
DELIVERY_QUEUE_POLL_MS=2000
PROVIDER_HTTP_TIMEOUT_MS=10000

# Outbound SMS. Local simulation logs without sending; production uses disabled, twilio, or brevo.
SMS_PROVIDER=simulation
SMS_SENDER=CHPM
SMS_JOB_MAX_ATTEMPTS=3
SMS_JOB_RETRY_DELAY_MS=1000
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
BREVO_API_KEY=""
SENDGRID_API_KEY=""
MAILJET_API_KEY=""
MAILJET_API_SECRET=""
# Dedicated bearer token for GET /api/metrics/prometheus in production.
METRICS_TOKEN=""
