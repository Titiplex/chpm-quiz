VITE_I18N_CONTENT_BASE_URL=/content/i18n
VITE_DEFAULT_LOCALE=fr
VITE_APP_DESCRIPTION="Secure questionnaire, invitation, response, and pseudonymized statistics platform."
VITE_APP_NAME="CHPM Survey"
VITE_API_BASE_URL=http://localhost:3000/api

# Backend hardening auth/identity.
OPERATIONAL_DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=public"
IDENTITY_DATABASE_URL="postgresql://chpm:chpm@localhost:5432/chpm_quiz?schema=identity"
EMAIL_IDENTITY_DISABLED_FOR_APP=true
EXPOSE_RESPONDENT_DEV_LINKS=true
AUTH_PROVIDER=local
AUTH_OIDC_ISSUER=""
AUTH_SAML_ENTITY_ID=""
AUTH_AUDIENCE=""
AUTH_METADATA_URL=""
AUTH_CALLBACK_PATH=/api/auth/callback

# Outbound email. Production must use brevo, sendgrid, or mailjet; never simulation.
EMAIL_PROVIDER=simulation
EMAIL_FROM=no-reply@chpm.local
EMAIL_FROM_NAME="CHPM Survey"
EMAIL_JOB_MAX_ATTEMPTS=3
EMAIL_JOB_RETRY_DELAY_MS=1000

# Outbound SMS. Local simulation logs without sending; production uses disabled, twilio, or brevo.
SMS_PROVIDER=simulation
SMS_SENDER=CHPM
SMS_JOB_MAX_ATTEMPTS=3
SMS_JOB_RETRY_DELAY_MS=1000
BREVO_API_KEY=""
SENDGRID_API_KEY=""
MAILJET_API_KEY=""
MAILJET_API_SECRET=""

# GDPR / encrypted exports
SECURE_DOCUMENT_KEY_B64=
SECURE_DOCUMENT_KEY_REF=env:SECURE_DOCUMENT_KEY_B64
DEV_SECURE_DOCUMENT_SECRET=development-secure-document-key-change-me
PSEUDONYMIZED_EXPORT_TTL_MINUTES=1440
JUDICIAL_EXPORT_TTL_MINUTES=15
EXPIRED_TOKEN_PURGE_DAYS=7
RESPONSE_RETENTION_DAYS=730
QUESTIONNAIRE_METADATA_RETENTION_DAYS=3650
DEFAULT_LOCALE=fr
